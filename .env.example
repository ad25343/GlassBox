# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google (Gemini / Vertex AI) ───────────────────────────────────────────────
GOOGLE_API_KEY=AIza...
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_REGION=us-central1

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# Alerts (optional — leave blank to disable)
SLACK_WEBHOOK_URL=           # e.g. https://hooks.slack.com/services/xxx
ALERT_EMAIL=                 # e.g. alerts@yourcompany.com

# Basic auth (optional — leave blank to disable auth in dev)
GLASSBOX_USERNAME=
GLASSBOX_PASSWORD=

# Token pricing for cost dashboard (USD per token — update as model pricing changes)
INPUT_TOKEN_PRICE=0.000003   # $3.00 / 1M input tokens (Sonnet default)
OUTPUT_TOKEN_PRICE=0.000015  # $15.00 / 1M output tokens (Sonnet default)
